{
  "name": "publio",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "pnpm --filter @publio/web dev",
    "dev:api": "pnpm --filter @publio/api dev",
    "build": "pnpm --filter @publio/web build",
    "preview": "pnpm --filter @publio/web preview",
    "lint": "eslint apps/web/src --ext .ts,.tsx",
    "check:no-js-source": "tsx scripts/check-no-js-source.ts",
    "test": "vitest run --passWithNoTests",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css.ts,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "fast-uri": ">=3.1.2",
      "shell-quote": ">=1.8.4",
      "esbuild": ">=0.28.1",
      "js-yaml": ">=4.2.0",
      "@babel/core": ">=7.29.7",
      "undici": "7.28.0"
    }
  }
}
